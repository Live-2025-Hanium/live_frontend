{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (Chrome 3000 localhost)",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d", "chrome",
        "--web-port", "3000",
        "--web-hostname", "localhost",
        "--dart-define-from-file=.vscode/dart-defines.local.json"
      ]
    },
    {
      "name": "Flutter (Android)",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d", "android",
        "--dart-define-from-file=.vscode/dart-defines.local.json"
      ]
    },
    {
      "name": "Flutter (iOS - iPhone 13 mini)",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d", "iPhone 13 mini",
        "--dart-define-from-file=.vscode/dart-defines.local.json"
      ]
    }
  ]
}
